PORT=8787
PUBLIC_BASE_URL=https://relay.example.com
APP_NAME=Codex Relay
DATA_DIR=./data

PUBLIC_ACCESS_TOKEN=replace-with-a-web-access-token
BRIDGE_SHARED_SECRET=replace-with-a-long-random-secret

RELAY_SERVER_URL=http://127.0.0.1:8787
BRIDGE_PROJECT_ROOTS=C:\Projects;D:\Projects
BRIDGE_PROJECT_CONTAINER_NAMES=Projects
BRIDGE_PROJECT_EXCLUDE_NAMES=codex,node_modules,.git,$recycle.bin,system volume information
BRIDGE_INCLUDE_SINGLE_FILES=false
BRIDGE_DEFAULT_PROJECT_ID=main-project

BRIDGE_CODEX_LOG_ROOT=
BRIDGE_CODEX_EXE=
BRIDGE_POLL_INTERVAL_MS=4000
BRIDGE_CODEX_EXEC_TIMEOUT_MS=1800000
BRIDGE_MOCK_MODE=false
BRIDGE_TAIL_CODEX_LOGS=true
